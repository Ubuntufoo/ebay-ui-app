NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy compatibility fallbacks while older local env files are migrated.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required sidecar endpoint.
# Recommended local split: UI on 3000, sidecar on 3001.
SIDECAR_API_URL=http://localhost:3001

# Optional server-side bearer token for sidecar REST requests.
# In local development, start the sidecar with OAUTH_ENABLED=false.
SIDECAR_API_BEARER_TOKEN=
